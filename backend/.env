# ================== DATABASE ==================
DB_USER=litera_user
DB_PASSWORD=litera_pass
DB_NAME=litera_db
# Для запуска через Docker Compose используется хост "postgres"
# Для локального запуска замените "postgres" на "localhost"
DATABASE_URL=postgresql+asyncpg://litera_user:litera_pass@postgres:5432/litera_db

# ================== MINIO / S3 ==================
# Для Docker Compose: http://minio:9000
# Для локального запуска: http://localhost:9000
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=books
MINIO_SECURE=false
PRESIGNED_URL_EXPIRE_MINUTES=60

# ================== JWT ==================
# ВАЖНО: замените на случайную строку перед деплоем в продакшн
SECRET_KEY=your-very-long-random-secret-key-min-50-symbols-change-me-in-production-2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
